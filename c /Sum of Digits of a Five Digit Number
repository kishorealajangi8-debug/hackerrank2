#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    
    int n;
    scanf("%d", &n);
    
    int sum = 0;
    
    // Since the input is exactly 5 digits, we loop 5 times
    for (int i = 0; i < 5; i++) {
        // 1. Get the last digit and add it to sum
        sum += (n % 10);
        
        // 2. Remove the last digit from n using integer division
        n = n / 10;
    }
    
    printf("%d\n", sum);
    
    return 0;
}
